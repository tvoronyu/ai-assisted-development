# Database connection (asyncpg driver). Override DATABASE_URL in your local .env.
DATABASE_URL=postgresql+asyncpg://tickets:tickets@localhost:5432/tickets

# Maximum upload size for bulk import endpoints (bytes).
# Default: 536870912 (512 MiB).
# Tune this together with worker memory limits and request timeouts —
# raising it without raising those will cause OOM on large files.
MAX_UPLOAD_SIZE_BYTES=536870912

# Logging
LOG_LEVEL=INFO

# App environment: development | test | production
APP_ENV=development
